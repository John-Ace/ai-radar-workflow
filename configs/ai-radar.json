{
  "name": "AI 信息雷达",
  "outputDir": "runs/ai-radar",
  "defaultLimit": 50,
  "selection": {
    "minItems": 25,
    "targetItems": 25,
    "maxItems": 25,
    "maxPerSource": 5,
    "maxPerGroup": 12,
    "freshness": {
      "maxPreviousCalendarDays": 1,
      "requireDate": true,
      "allowFutureHours": 6
    }
  },
  "archive": {
    "opencliDataDir": "opencli 数据爬取库",
    "briefDir": "AI 日报库",
    "dataFileSuffix": "数据爬取",
    "briefFileSuffix": "AI 日报"
  },
  "automation": {
    "logPath": "logs/ai-radar-fetch.log",
    "errLogPath": "logs/ai-radar-fetch.err.log"
  },
  "communityTrust": {
    "trustedAuthors": {
      "twitter": [
        "OpenAI",
        "AnthropicAI",
        "claudeai",
        "GoogleDeepMind",
        "AIatMeta",
        "HuggingFace",
        "sama",
        "gdb",
        "karpathy",
        "demishassabis",
        "DarioAmodei"
      ],
      "reddit": [],
      "hackernews": []
    },
    "trustedDomains": [
      "openai.com",
      "anthropic.com",
      "deepmind.google",
      "ai.meta.com",
      "huggingface.co",
      "github.com",
      "arxiv.org"
    ],
    "lowValuePatterns": [
      "bookmark",
      "save this",
      "worth than $500",
      "worth $500",
      "10 tools",
      "make money",
      "course",
      "formation",
      "signet",
      "500$",
      "replace one movie",
      "monetize"
    ]
  },
  "officialKeywords": ["AI", "agent", "model", "ChatGPT", "Claude", "Gemini", "Llama", "DeepSeek", "Qwen", "GLM", "Kimi", "MCP", "workflow", "skills"],
