    {
      "id": "arxiv-llm",
      "name": "arXiv LLM / Agent",
      "group": "论文与研究",
      "type": "opencli-keyword",
      "enabled": false,
      "keywords": ["large language model", "AI agent", "multimodal reasoning"],
      "command": ["opencli", "arxiv", "search", "{keyword}", "--limit", "{limit}", "-f", "json"],
      "limit": 8
    },
    {
      "id": "huggingface-models",
      "name": "Hugging Face Trending Models",
      "group": "模型与工具",
      "type": "opencli",
      "command": ["opencli", "hf", "models", "--sort", "downloads", "--limit", "{limit}", "-f", "json"],
      "limit": 50
    },
    {
      "id": "huggingface-papers",
      "name": "Hugging Face Top Papers",
      "group": "论文与研究",
      "type": "opencli",
      "command": ["opencli", "hf", "top", "--limit", "{limit}", "-f", "json"],
      "limit": 50
    },
    {
      "id": "hackernews",
      "name": "Hacker News",
      "group": "海外社区热度",
      "type": "opencli-keyword",
      "keywords": ["AI", "LLM", "OpenAI", "Claude", "AI agent", "MCP agent", "agent workflow"],
      "command": ["opencli", "hackernews", "search", "{keyword}", "--limit", "{limit}", "-f", "json"],
      "limit": 50
    },
    {
      "id": "twitter",
      "name": "Twitter/X",
      "group": "海外社区热度",
      "type": "opencli-keyword",
      "keywords": ["AI agent", "OpenAI", "Claude", "LLM", "Claude Code skills", "MCP agent", "agent workflow"],
      "command": ["opencli", "twitter", "search", "{keyword}", "--limit", "{limit}", "-f", "json"],
      "limit": 50
    },
    {
      "id": "reddit",
      "name": "Reddit",
      "group": "海外社区热度",
      "type": "opencli-keyword",
      "enabled": false,
      "keywords": ["AI", "LLM", "ChatGPT", "Claude", "Claude Code skills", "AI agent skill"],
      "command": ["opencli", "reddit", "search", "{keyword}", "--sort", "new", "--time", "day", "--limit", "{limit}", "-f", "json"],
      "limit": 20
    },
    {
      "id": "github",
      "name": "GitHub",
      "group": "开源项目趋势",
      "type": "github-search",
      "keywords": ["ai agent", "llm", "rag", "multimodal", "agent skill", "mcp agent", "agent workflow"],
      "limit": 50
    },
    {
      "id": "devto-ai",
      "name": "DEV.to AI",
      "group": "开发者与产品源",
      "type": "opencli-keyword",
      "keywords": ["ai", "llm", "machinelearning", "openai"],
      "command": ["opencli", "devto", "tag", "{keyword}", "--limit", "{limit}", "-f", "json"],
      "limit": 50
    },
    {
      "id": "producthunt-today",
      "name": "Product Hunt Today",
      "group": "开发者与产品源",
      "type": "opencli",
      "command": ["opencli", "producthunt", "today", "--limit", "{limit}", "-f", "json"],
      "assumeCurrentDate": true,
      "limit": 50
    }
  ]
}
