# Optional local overrides. Copy to .env.local only if needed.

# By default, AI Radar auto-detects a supported local agent CLI.
# Use AI_RADAR_AGENT only when multiple supported agents are installed.
# Supported values: auto, workbuddy, claude, codex, openclaw.
# AI_RADAR_AGENT=auto

# Use AGENT_BRIEF_COMMAND only when you want a custom agent command.
# The command receives these environment variables:
# AI_RADAR_RUN_DIR, AI_RADAR_ANALYSIS_INPUT, AI_RADAR_SELECTED_RESULTS,
# AI_RADAR_SELECTION_REPORT, AI_RADAR_TEMPLATE, AI_RADAR_OUTPUT, AI_RADAR_PROMPT.
#
# Example shape:
# AGENT_BRIEF_COMMAND=your-agent-cli run "$AI_RADAR_PROMPT"

# Proxy variables if your OpenCLI sources need them.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
