# Optional local overrides. Copy to .env.local if needed.

# Absolute path to Codex CLI when it is not available as `codex` on PATH.
# CODEX_CLI=/absolute/path/to/codex

# Proxy variables if your OpenCLI sources need them.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
